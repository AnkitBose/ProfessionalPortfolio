---
import ThemeToggle from "@/components/ThemeToggle";
import { toBasePath } from "@/config/site";

const navItems = [
  { label: "Home", href: toBasePath("") },
  { label: "About", href: toBasePath("about/") },
  { label: "Projects", href: toBasePath("projects/") },
  { label: "Labs", href: toBasePath("labs/") },
  { label: "Resume", href: toBasePath("resume/") },
  { label: "Contact", href: toBasePath("contact/") }
];
---

<header class="border-b border-border/70 bg-surface/85 backdrop-blur">
  <div class="container flex flex-wrap items-center justify-between gap-4 py-4">
    <a class="focus-ring font-mono text-sm font-semibold tracking-wide text-accent" href={toBasePath("")}
      >ankit-bose.dev</a
    >
    <nav aria-label="Main navigation" class="flex items-center gap-1 sm:gap-2">
      {
        navItems.map((item) => (
          <a
            class="focus-ring rounded-md px-3 py-2 text-sm text-muted transition hover:text-text"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle client:load />
    </nav>
  </div>
</header>
