---
interface Props {
  title: string;
  summary: string;
  href: string;
  tags: string[];
  date: Date;
}

const { title, summary, href, tags, date } = Astro.props;
---

<article class="card p-5 transition hover:border-accent/50" data-filter-item data-tags={tags.join(",").toLowerCase()}>
  <h2 class="text-lg font-semibold"><a class="focus-ring hover:text-accent" href={href}>{title}</a></h2>
  <p class="mt-3 text-sm leading-6 text-muted">{summary}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))
    }
  </div>
  <p class="mt-4 font-mono text-xs text-muted">{date.toISOString().slice(0, 10)}</p>
</article>
