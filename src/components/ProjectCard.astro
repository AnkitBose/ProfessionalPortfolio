---
interface Props {
  title: string;
  summary: string;
  href: string;
  tags: string[];
  date: Date;
  featured?: boolean;
}

const { title, summary, href, tags, date, featured = false } = Astro.props;
---

<article class="card p-5 transition hover:border-accent/50 hover:shadow-glow" data-filter-item data-tags={tags.join(",").toLowerCase()}>
  <header class="flex items-start justify-between gap-4">
    <h2 class="text-xl font-semibold tracking-tight"><a class="focus-ring hover:text-accent" href={href}>{title}</a></h2>
    {featured && <span class="tag border-accent text-accent">Featured</span>}
  </header>
  <p class="mt-3 text-sm leading-6 text-muted">{summary}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))
    }
  </div>
  <p class="mt-4 font-mono text-xs text-muted">Updated {date.toISOString().slice(0, 10)}</p>
</article>
