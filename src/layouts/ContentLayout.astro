---
interface Props {
  title: string;
  date: Date;
  tags: string[];
}

const { title, date, tags } = Astro.props;
---

<article class="mx-auto max-w-3xl">
  <header class="mb-8">
    <p class="font-mono text-sm text-muted">{date.toISOString().slice(0, 10)}</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">{title}</h1>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))
      }
    </div>
  </header>
  <div class="prose prose-invert max-w-none prose-a:text-accent dark:prose-invert light:prose-slate">
    <slot />
  </div>
</article>
