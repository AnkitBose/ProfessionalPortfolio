---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toBasePath } from "@/config/site";
---

<BaseLayout title="Not Found" description="The requested page could not be found." path="404/">
  <section class="mx-auto max-w-2xl text-center">
    <p class="font-mono text-sm text-accent">404</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-4 text-sm text-muted">The page may have moved or the URL may be incorrect.</p>
    <a class="focus-ring mt-6 inline-flex rounded-md border border-border px-4 py-2 text-sm" href={toBasePath("")}
      >Back to home</a
    >
  </section>
</BaseLayout>
